   <string notr="true">QDialog {
    background-color: #fff5f7;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
}

/* Etiquetas */
QLabel {
    color: #6b2d3a;
    font-size: 14px;
    font-weight: 500;
}

/* Campos de texto */
QLineEdit {
    background-color: #ffffff;
    border: 2px solid #f8c8dc;
    border-radius: 10px;
    padding: 6px 10px;
    font-size: 14px;
    color: #4a1f2b;
}

QLineEdit:focus {
    border: 2px solid #ec4899;
    background-color: #fff0f5;
}

/* Botón */
QPushButton {
    background-color: #ec4899;
    color: white;
    border-radius: 12px;
    padding: 8px;
    font-size: 14px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #db2777;
}

QPushButton:pressed {
    background-color: #be185d;
}

/* Resultado (label especial) */
#labelResultado {
    font-size: 16px;
    font-weight: bold;
    color: #be185d;
}</string>
