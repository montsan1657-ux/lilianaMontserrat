  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-color: #f4f8fb;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
}

/* Barra de menú */
QMenuBar {
    background-color: #dbeafe;
    color: #1e3a5f;
    font-size: 48px;
    padding: 10px;
}

/* Elementos del menú */
QMenuBar::item {
    background-color: transparent;
    padding: 10px 20px;
    margin: 5px;
    border-radius: 8px;
}

QMenuBar::item:selected {
    background-color: #93c5fd;
    color: #0f172a;
}

QMenuBar::item:pressed {
    background-color: #60a5fa;
}

/* Menú desplegable */
QMenu {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    font-size: 48px;
    color: #1e293b;
}

/* Opciones dentro del menú (QAction) */
QMenu::item {
    padding: 12px 30px;
    border-radius: 6px;
}

QMenu::item:selected {
    background-color: #bfdbfe;
    color: #0f172a;
}

QMenu::item:disabled {
    color: #94a3b8;
}

/* Separadores */
QMenu::separator {
    height: 2px;
    background: #e2e8f0;
    margin: 8px 10px;
}
</string>
