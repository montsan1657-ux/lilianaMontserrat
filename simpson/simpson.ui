}

/* Inputs */
QLineEdit {
    background-color: white;
    border: 2px solid #d6c4e6;
    border-radius: 8px;
    padding: 6px;
    font-size: 14px;
    color: #3a2d4f;
}

QLineEdit:focus {
    border: 2px solid #b388eb;
    background-color: #faf7ff;
}

/* Botón */
QPushButton {
    background-color: #b388eb;
    color: white;
    border-radius: 10px;
    padding: 8px;
    font-size: 14px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #9c6fe4;
}

QPushButton:pressed {
    background-color: #7e57c2;
}

/* Resultado (puedes usar un QLabel especial) */
#labelResultado {
    font-size: 16px;
    font-weight: bold;
    color: #6a1b9a;
}</string>
